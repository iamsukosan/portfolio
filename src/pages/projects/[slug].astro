---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = async () => {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
};

const { project } = Astro.props;
const { Content } = await project.render();

const formattedDate = project.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title={project.data.title}
  description={project.data.description}
  ogType="article"
  publishedTime={project.data.date.toISOString()}
  tags={project.data.tags}
>
  <main class="project-main">
    <div class="section-container">

      <!-- Back -->
      <a href="/projects" class="back-link">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        All Projects
      </a>

      <!-- Header -->
      <header class="proj-header animate-fade-up">
        <div class="proj-meta">
          <time datetime={project.data.date.toISOString()} class="proj-date">{formattedDate}</time>
          <span class={`card-status status-${project.data.status}`}>{project.data.status}</span>
          {project.data.featured && <span class="featured-badge">Featured</span>}
        </div>

        <h1 class="proj-title">{project.data.title}</h1>
        <p class="proj-desc">{project.data.description}</p>

        <div class="proj-tags">
          {project.data.tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>

        <!-- External links -->
        {(project.data.githubUrl || project.data.liveUrl) && (
          <div class="proj-links">
            {project.data.githubUrl && (
              <a href={project.data.githubUrl} target="_blank" rel="noopener noreferrer" class="proj-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                View on GitHub
              </a>
            )}
            {project.data.liveUrl && (
              <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="proj-link proj-link-primary">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                  <path d="M8 3H3C2.45 3 2 3.45 2 4V13C2 13.55 2.45 14 3 14H12C12.55 14 13 13.55 13 13V8M10 2H14M14 2V6M14 2L7 9" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                Live project
              </a>
            )}
          </div>
        )}
      </header>

      <div class="divider"></div>

      <!-- Content -->
      <article class="prose prose-invert prose-lg max-w-none animate-fade-in animate-fade-up-d1">
        <Content />
      </article>

      <!-- Footer nav -->
      <div class="proj-footer">
        <a href="/projects" class="back-link">
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
            <path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          All Projects
        </a>
        <a href="mailto:iamsukosan@gmail.com" class="btn-hire">
          Work with me →
        </a>
      </div>

    </div>
  </main>
</BaseLayout>

<style>
  .project-main {
    padding-top: 120px;
    padding-bottom: 4rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    text-decoration: none;
    margin-bottom: 2.5rem;
    transition: color 0.2s ease;
  }

  .back-link:hover { color: var(--accent-green); }

  .proj-header { margin-bottom: 2rem; }

  .proj-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 1.25rem;
  }

  .proj-date {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-subtle);
  }

  .card-status {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    text-transform: capitalize;
  }

  .status-completed {
    color: var(--accent-soft);
    background: rgba(0, 255, 136, 0.08);
    border: 1px solid rgba(0, 255, 136, 0.2);
  }

  .status-in-progress {
    color: #fbbf24;
    background: rgba(251, 191, 36, 0.08);
    border: 1px solid rgba(251, 191, 36, 0.2);
  }

  .featured-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent-green);
    background: rgba(57, 255, 20, 0.08);
    border: 1px solid rgba(57, 255, 20, 0.2);
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    letter-spacing: 0.06em;
  }

  .proj-title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin-bottom: 1rem;
  }

  .proj-desc {
    font-size: 1.1rem;
    color: var(--text-muted);
    max-width: 65ch;
    line-height: 1.65;
    margin-bottom: 1.25rem;
  }

  .proj-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .proj-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .proj-link {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    border: 1px solid var(--border-default);
    padding: 0.5rem 1rem;
    border-radius: 8px;
    text-decoration: none;
    transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
  }

  .proj-link:hover {
    color: var(--text-primary);
    border-color: rgba(255, 255, 255, 0.18);
    background: rgba(255, 255, 255, 0.04);
  }

  .proj-link-primary {
    color: var(--accent-green);
    border-color: rgba(57, 255, 20, 0.3);
  }

  .proj-link-primary:hover {
    background: rgba(57, 255, 20, 0.07);
    border-color: rgba(57, 255, 20, 0.5);
    color: var(--accent-green);
  }

  .proj-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-default);
    flex-wrap: wrap;
    gap: 1rem;
  }

  .btn-hire {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: #020917;
    background: var(--accent-green);
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    text-decoration: none;
    box-shadow: 0 0 18px rgba(57, 255, 20, 0.25);
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }

  .btn-hire:hover {
    box-shadow: 0 0 30px rgba(57, 255, 20, 0.45);
    transform: translateY(-2px);
  }

  @media (max-width: 640px) {
    .project-main { padding-top: 100px; }
    .proj-footer { flex-direction: column; align-items: flex-start; }
  }
</style>
