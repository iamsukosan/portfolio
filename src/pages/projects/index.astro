---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const allProjects = (await getCollection("projects")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

const featuredProjects = allProjects.filter((p) => p.data.featured);
const otherProjects = allProjects.filter((p) => !p.data.featured);

const allTags = [...new Set(allProjects.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Projects"
  description="AI automation workflows, DevOps infrastructure setups, and Cloudflare security projects by Sudarshan Kotian."
>
  <main class="projects-main">
    <div class="section-container">
      <div class="projects-hero-wrap">
        <canvas id="node-graph" aria-hidden="true"></canvas>
        <!-- Header -->
        <header class="page-header animate-fade-up">
          <p class="eyebrow">All work</p>
          <h1 class="page-title">Projects</h1>
          <p class="page-desc">
            A collection of AI automation workflows, DevOps infrastructure
            builds, and security engineering projects — built with production
            environments in mind.
          </p>
        </header>

        <!-- Tag filter display (decorative, not JS-driven) -->
        <div class="tags-strip animate-fade-up animate-fade-up-d1">
          {allTags.map((tag) => <span class="tag">{tag}</span>)}
        </div>

        <!-- Featured -->
        {
          featuredProjects.length > 0 && (
            <section class="project-section animate-fade-up animate-fade-up-d2">
              <h2 class="section-label">Featured</h2>
              <div class="projects-grid featured-grid">
                {featuredProjects.map((project) => (
                  <a
                    href={`/projects/${project.id}`}
                    class="project-card glass-card"
                  >
                    <div class="card-inner">
                      <div class="card-top">
                        <div class="card-tags">
                          {project.data.tags.slice(0, 3).map((tag: string) => (
                            <span class="tag">{tag}</span>
                          ))}
                        </div>
                        <div class="card-badge">
                          <span class="featured-badge">Featured</span>
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 18 18"
                            fill="none"
                            class="card-arrow"
                            aria-hidden="true"
                          >
                            <path
                              d="M3.5 14.5L14.5 3.5M14.5 3.5H6.5M14.5 3.5V11.5"
                              stroke="currentColor"
                              stroke-width="1.5"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                            />
                          </svg>
                        </div>
                      </div>
                      <div class="card-body">
                        <h3 class="card-title">{project.data.title}</h3>
                        <p class="card-desc">{project.data.description}</p>
                      </div>
                      <div class="card-footer">
                        <time class="card-date">
                          {project.data.date.toLocaleDateString("en-US", {
                            year: "numeric",
                            month: "long",
                          })}
                        </time>
                        <span
                          class={`card-status status-${project.data.status}`}
                        >
                          {project.data.status}
                        </span>
                      </div>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )
        }

        <!-- Other projects -->
        {
          otherProjects.length > 0 && (
            <section class="project-section animate-fade-up animate-fade-up-d3">
              <h2 class="section-label">All projects</h2>
              <div class="projects-list">
                {otherProjects.map((project) => (
                  <a
                    href={`/projects/${project.id}`}
                    class="project-row glass-card"
                  >
                    <div class="row-left">
                      <h3 class="row-title">{project.data.title}</h3>
                      <p class="row-desc">{project.data.description}</p>
                      <div class="row-tags">
                        {project.data.tags.slice(0, 4).map((tag: string) => (
                          <span class="tag">{tag}</span>
                        ))}
                      </div>
                    </div>
                    <div class="row-right">
                      <time class="card-date">
                        {project.data.date.toLocaleDateString("en-US", {
                          year: "numeric",
                          month: "short",
                        })}
                      </time>
                      <svg
                        width="18"
                        height="18"
                        viewBox="0 0 18 18"
                        fill="none"
                        class="card-arrow"
                        aria-hidden="true"
                      >
                        <path
                          d="M3.5 14.5L14.5 3.5M14.5 3.5H6.5M14.5 3.5V11.5"
                          stroke="currentColor"
                          stroke-width="1.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        />
                      </svg>
                    </div>
                  </a>
                ))}
              </div>
            </section>
          )
        }
      </div>
    </div>
    <script is:inline>
      (function () {
        var raf = null;
        var running = false;

        /* ── PALETTE ── */
        var GREEN = "#39ff14";
        var SOFT = "#00ff88";
        var CYAN = "#00d4ff";
        var COLORS = [GREEN, SOFT, CYAN];

        /* ── TOOL ICON DRAW FUNCTIONS ── */
        /* Each draws a simplified monochrome logo centered at (0,0) scaled by s */
        var TOOLS = [
          {
            name: "Docker",
            draw: function (c, s) {
              c.beginPath();
              c.moveTo(-s * 0.9, -s * 0.1);
              c.lineTo(s * 0.9, -s * 0.1);
              c.quadraticCurveTo(s * 1.0, 0, s * 0.9, s * 0.2);
              c.lineTo(s * 0.5, s * 0.5);
              c.quadraticCurveTo(0, s * 0.7, -s * 0.5, s * 0.5);
              c.lineTo(-s * 0.9, s * 0.2);
              c.quadraticCurveTo(-s * 1.0, 0, -s * 0.9, -s * 0.1);
              c.closePath();
              c.stroke();
              var bw = s * 0.28,
                bh = s * 0.22,
                sx = -s * 0.55,
                sy = -s * 0.65;
              for (var r = 0; r < 2; r++) {
                for (var cc = 0; cc < 3; cc++) {
                  c.strokeRect(
                    sx + cc * (bw + s * 0.06),
                    sy + r * (bh + s * 0.06),
                    bw,
                    bh,
                  );
                }
              }
            },
          },
          {
            name: "Cloudflare",
            draw: function (c, s) {
              c.beginPath();
              c.moveTo(-s * 0.3, -s * 0.6);
              c.quadraticCurveTo(-s * 0.9, -s * 0.7, -s * 0.8, -s * 0.1);
              c.quadraticCurveTo(-s * 1.0, s * 0.5, -s * 0.3, s * 0.5);
              c.lineTo(s * 0.7, s * 0.5);
              c.quadraticCurveTo(s * 1.0, s * 0.5, s * 1.0, s * 0.1);
              c.quadraticCurveTo(s * 1.0, -s * 0.3, s * 0.6, -s * 0.3);
              c.quadraticCurveTo(s * 0.5, -s * 0.8, 0, -s * 0.7);
              c.quadraticCurveTo(-s * 0.2, -s * 0.65, -s * 0.3, -s * 0.6);
              c.closePath();
              c.stroke();
            },
          },
          {
            name: "GitHub",
            draw: function (c, s) {
              c.beginPath();
              c.arc(0, -s * 0.15, s * 0.7, 0, Math.PI * 2);
              c.stroke();
              c.beginPath();
              c.arc(-s * 0.25, -s * 0.3, s * 0.12, 0, Math.PI * 2);
              c.stroke();
              c.beginPath();
              c.arc(s * 0.25, -s * 0.3, s * 0.12, 0, Math.PI * 2);
              c.stroke();
              c.beginPath();
              c.moveTo(0, s * 0.55);
              c.lineTo(0, s * 0.9);
              c.moveTo(-s * 0.35, s * 0.55);
              c.quadraticCurveTo(-s * 0.35, s * 0.9, -s * 0.15, s * 0.9);
              c.stroke();
            },
          },
          {
            name: "n8n",
            draw: function (c, s) {
              c.beginPath();
              c.arc(0, 0, s * 0.75, 0, Math.PI * 2);
              c.stroke();
              c.beginPath();
              c.arc(-s * 0.25, 0, s * 0.15, 0, Math.PI * 2);
              c.fill();
              c.beginPath();
              c.arc(s * 0.25, 0, s * 0.15, 0, Math.PI * 2);
              c.fill();
              c.beginPath();
              c.moveTo(-s * 0.1, 0);
              c.lineTo(s * 0.1, 0);
              c.stroke();
            },
          },
          {
            name: "Redis",
            draw: function (c, s) {
              c.beginPath();
              c.moveTo(0, -s * 0.85);
              c.lineTo(s * 0.7, 0);
              c.lineTo(0, s * 0.85);
              c.lineTo(-s * 0.7, 0);
              c.closePath();
              c.stroke();
              c.beginPath();
              c.moveTo(-s * 0.35, 0);
              c.lineTo(s * 0.35, 0);
              c.moveTo(0, -s * 0.42);
              c.lineTo(0, s * 0.42);
              c.stroke();
            },
          },
          {
            name: "PostgreSQL",
            draw: function (c, s) {
              c.beginPath();
              c.ellipse(0, -s * 0.15, s * 0.6, s * 0.7, 0, 0, Math.PI * 2);
              c.stroke();
              c.beginPath();
              c.moveTo(s * 0.25, -s * 0.55);
              c.quadraticCurveTo(s * 0.7, -s * 0.3, s * 0.5, s * 0.2);
              c.quadraticCurveTo(s * 0.3, s * 0.7, s * 0.5, s * 0.9);
              c.stroke();
              c.beginPath();
              c.moveTo(-s * 0.15, s * 0.2);
              c.lineTo(s * 0.15, s * 0.2);
              c.stroke();
            },
          },
          {
            name: "Astro",
            draw: function (c, s) {
              c.beginPath();
              c.moveTo(0, -s * 0.9);
              c.lineTo(s * 0.55, s * 0.7);
              c.quadraticCurveTo(s * 0.3, s * 0.4, 0, s * 0.5);
              c.quadraticCurveTo(-s * 0.3, s * 0.4, -s * 0.55, s * 0.7);
              c.closePath();
              c.stroke();
              c.beginPath();
              c.arc(0, -s * 0.15, s * 0.12, 0, Math.PI * 2);
              c.fill();
            },
          },
          {
            name: "Kubernetes",
            draw: function (c, s) {
              var pts = 7,
                r1 = s * 0.8,
                r2 = s * 0.55;
              c.beginPath();
              for (var i = 0; i < pts; i++) {
                var a1 = (Math.PI * 2 * i) / pts - Math.PI / 2;
                var a2 = (Math.PI * 2 * (i + 0.5)) / pts - Math.PI / 2;
                c.lineTo(Math.cos(a1) * r1, Math.sin(a1) * r1);
                c.lineTo(Math.cos(a2) * r2, Math.sin(a2) * r2);
              }
              c.closePath();
              c.stroke();
              c.beginPath();
              c.arc(0, 0, s * 0.2, 0, Math.PI * 2);
              c.stroke();
            },
          },
          {
            name: "Terraform",
            draw: function (c, s) {
              var w = s * 0.5,
                h = s * 0.35,
                g = s * 0.08;
              c.fillRect(-w - g / 2, -h - g / 2, w, h);
              c.fillRect(g / 2, -h - g / 2, w, h);
              c.fillRect(g / 2, g / 2, w, h);
              c.fillRect(-w - g / 2, g / 2 + h + g, w, h);
            },
          },
          {
            name: "Nginx",
            draw: function (c, s) {
              c.beginPath();
              c.moveTo(-s * 0.5, -s * 0.7);
              c.lineTo(-s * 0.5, s * 0.7);
              c.moveTo(-s * 0.5, -s * 0.7);
              c.lineTo(s * 0.5, s * 0.7);
              c.moveTo(s * 0.5, -s * 0.7);
              c.lineTo(s * 0.5, s * 0.7);
              c.stroke();
            },
          },
          {
            name: "Python",
            draw: function (c, s) {
              c.beginPath();
              c.moveTo(-s * 0.1, -s * 0.85);
              c.quadraticCurveTo(-s * 0.7, -s * 0.85, -s * 0.7, -s * 0.3);
              c.lineTo(-s * 0.7, s * 0.1);
              c.lineTo(s * 0.1, s * 0.1);
              c.lineTo(s * 0.1, -s * 0.3);
              c.lineTo(-s * 0.35, -s * 0.3);
              c.stroke();
              c.beginPath();
              c.moveTo(s * 0.1, s * 0.85);
              c.quadraticCurveTo(s * 0.7, s * 0.85, s * 0.7, s * 0.3);
              c.lineTo(s * 0.7, -s * 0.1);
              c.lineTo(-s * 0.1, -s * 0.1);
              c.lineTo(-s * 0.1, s * 0.3);
              c.lineTo(s * 0.35, s * 0.3);
              c.stroke();
              c.beginPath();
              c.arc(-s * 0.35, -s * 0.6, s * 0.1, 0, Math.PI * 2);
              c.fill();
              c.beginPath();
              c.arc(s * 0.35, s * 0.6, s * 0.1, 0, Math.PI * 2);
              c.fill();
            },
          },
          {
            name: "Grafana",
            draw: function (c, s) {
              c.beginPath();
              c.arc(0, 0, s * 0.75, 0, Math.PI * 2);
              c.stroke();
              c.beginPath();
              c.moveTo(-s * 0.4, s * 0.2);
              c.lineTo(-s * 0.15, -s * 0.3);
              c.lineTo(s * 0.15, s * 0.05);
              c.lineTo(s * 0.4, -s * 0.2);
              c.stroke();
            },
          },
          {
            name: "Supabase",
            draw: function (c, s) {
              c.beginPath();
              c.moveTo(s * 0.1, -s * 0.9);
              c.lineTo(-s * 0.5, s * 0.15);
              c.quadraticCurveTo(-s * 0.55, s * 0.25, -s * 0.35, s * 0.25);
              c.lineTo(0, s * 0.25);
              c.stroke();
              c.beginPath();
              c.moveTo(-s * 0.1, s * 0.9);
              c.lineTo(s * 0.5, -s * 0.15);
              c.quadraticCurveTo(s * 0.55, -s * 0.25, s * 0.35, -s * 0.25);
              c.lineTo(0, -s * 0.25);
              c.stroke();
            },
          },
          {
            name: "Nextjs",
            draw: function (c, s) {
              c.beginPath();
              c.arc(0, 0, s * 0.75, 0, Math.PI * 2);
              c.stroke();
              c.beginPath();
              c.moveTo(-s * 0.25, -s * 0.3);
              c.lineTo(-s * 0.25, s * 0.3);
              c.moveTo(-s * 0.25, -s * 0.3);
              c.lineTo(s * 0.35, s * 0.3);
              c.moveTo(s * 0.2, -s * 0.3);
              c.lineTo(s * 0.2, s * 0.3);
              c.stroke();
            },
          },
          {
            name: "MongoDB",
            draw: function (c, s) {
              c.beginPath();
              c.moveTo(0, -s * 0.9);
              c.quadraticCurveTo(s * 0.5, -s * 0.4, s * 0.4, s * 0.2);
              c.quadraticCurveTo(s * 0.25, s * 0.7, 0, s * 0.9);
              c.quadraticCurveTo(-s * 0.25, s * 0.7, -s * 0.4, s * 0.2);
              c.quadraticCurveTo(-s * 0.5, -s * 0.4, 0, -s * 0.9);
              c.stroke();
              c.beginPath();
              c.moveTo(0, -s * 0.4);
              c.lineTo(0, s * 0.6);
              c.stroke();
            },
          },
          {
            name: "Tailwind",
            draw: function (c, s) {
              c.beginPath();
              c.moveTo(-s * 0.7, -s * 0.1);
              c.quadraticCurveTo(-s * 0.3, -s * 0.7, 0, -s * 0.3);
              c.quadraticCurveTo(s * 0.3, s * 0.1, s * 0.7, -s * 0.5);
              c.stroke();
              c.beginPath();
              c.moveTo(-s * 0.7, s * 0.4);
              c.quadraticCurveTo(-s * 0.3, -s * 0.2, 0, s * 0.2);
              c.quadraticCurveTo(s * 0.3, s * 0.65, s * 0.7, 0);
              c.stroke();
            },
          },
          {
            name: "Claude",
            draw: function (c, s) {
              c.beginPath();
              c.arc(0, -s * 0.1, s * 0.65, 0, Math.PI * 2);
              c.stroke();
              c.beginPath();
              c.arc(-s * 0.15, -s * 0.15, s * 0.08, 0, Math.PI * 2);
              c.fill();
              c.beginPath();
              c.arc(s * 0.15, -s * 0.15, s * 0.08, 0, Math.PI * 2);
              c.fill();
              c.beginPath();
              c.arc(0, s * 0.15, s * 0.15, 0.2, Math.PI - 0.2);
              c.stroke();
            },
          },
          {
            name: "LangChain",
            draw: function (c, s) {
              c.beginPath();
              c.arc(-s * 0.25, -s * 0.25, s * 0.3, 0, Math.PI * 2);
              c.stroke();
              c.beginPath();
              c.arc(s * 0.25, s * 0.25, s * 0.3, 0, Math.PI * 2);
              c.stroke();
              c.beginPath();
              c.arc(0, 0, s * 0.08, 0, Math.PI * 2);
              c.fill();
            },
          },
        ];

        /* ── STATE ── */
        var canvas, ctx, W, H;
        var nodes = [],
          conns = [],
          arrows = [],
          particles = [];
        var mouse = { x: -9999, y: -9999 };
        var time = 0;

        /* ── HELPERS ── */
        function ddist(a, b) {
          return Math.sqrt(
            (a.x - b.x) * (a.x - b.x) + (a.y - b.y) * (a.y - b.y),
          );
        }
        function bezPt(p0, cp, p1, t) {
          var m = 1 - t;
          return {
            x: m * m * p0.x + 2 * m * t * cp.x + t * t * p1.x,
            y: m * m * p0.y + 2 * m * t * cp.y + t * t * p1.y,
          };
        }
        function bezTan(p0, cp, p1, t) {
          var m = 1 - t;
          return {
            x: 2 * m * (cp.x - p0.x) + 2 * t * (p1.x - cp.x),
            y: 2 * m * (cp.y - p0.y) + 2 * t * (p1.y - cp.y),
          };
        }
        function h2r(hex) {
          return {
            r: parseInt(hex.slice(1, 3), 16),
            g: parseInt(hex.slice(3, 5), 16),
            b: parseInt(hex.slice(5, 7), 16),
          };
        }

        function resize() {
          var wrap = canvas.parentElement;
          if (!wrap) return;
          var r = window.devicePixelRatio || 1;
          var rect = wrap.getBoundingClientRect();
          W = rect.width;
          H = rect.height;
          canvas.width = W * r;
          canvas.height = H * r;
          ctx.setTransform(r, 0, 0, r, 0, 0);
        }

        /* ── SPAWN FUNCTIONS ── */
        function spawnArrow(ci) {
          arrows.push({
            ci: ci,
            t: Math.random() * 0.3,
            speed: 0.0015 + Math.random() * 0.005,
            color: COLORS[Math.floor(Math.random() * 3)],
            size: 4 + Math.random() * 2,
          });
        }

        function spawnBurst(x, y, color) {
          for (var i = 0; i < 5; i++) {
            var a = Math.random() * Math.PI * 2;
            var sp = 0.4 + Math.random() * 1.2;
            particles.push({
              x: x,
              y: y,
              vx: Math.cos(a) * sp,
              vy: Math.sin(a) * sp,
              life: 1,
              color: color,
              size: 1.2 + Math.random(),
            });
          }
        }

        /* ── INIT — builds all nodes, connections, initial arrows ── */
        function init() {
          resize();
          nodes = [];
          conns = [];
          arrows = [];
          particles = [];
          var pad = 80;
          var i, j, d;

          /* Main tool nodes */
          for (i = 0; i < TOOLS.length; i++) {
            var attempts = 0,
              x,
              y,
              ok;
            do {
              x = pad + Math.random() * (W - pad * 2);
              y = pad + Math.random() * (H - pad * 2);
              ok = true;
              for (j = 0; j < nodes.length; j++) {
                if (ddist({ x: x, y: y }, nodes[j]) < 110) {
                  ok = false;
                  break;
                }
              }
              attempts++;
            } while (!ok && attempts < 200);
            nodes.push({
              x: x,
              y: y,
              baseX: x,
              baseY: y,
              vx: 0,
              vy: 0,
              tool: i,
              main: true,
              iconSize: 13,
              pulsePhase: Math.random() * Math.PI * 2,
            });
          }

          /* Secondary ambient nodes */
          var secCount = 14;
          for (i = 0; i < secCount; i++) {
            var att2 = 0,
              sx,
              sy,
              ok2;
            do {
              sx = 40 + Math.random() * (W - 80);
              sy = 40 + Math.random() * (H - 80);
              ok2 = true;
              for (j = 0; j < nodes.length; j++) {
                if (ddist({ x: sx, y: sy }, nodes[j]) < 65) {
                  ok2 = false;
                  break;
                }
              }
              att2++;
            } while (!ok2 && att2 < 150);
            nodes.push({
              x: sx,
              y: sy,
              baseX: sx,
              baseY: sy,
              vx: 0,
              vy: 0,
              tool: -1,
              main: false,
              iconSize: 0,
              pulsePhase: Math.random() * Math.PI * 2,
            });
          }

          /* Build connections with bezier curves */
          var maxD = 260;
          for (i = 0; i < nodes.length; i++) {
            var nodeConns = 0;
            for (j = i + 1; j < nodes.length; j++) {
              d = ddist(nodes[i], nodes[j]);
              if (d < maxD) {
                var prob =
                  nodes[i].main && nodes[j].main
                    ? 0.7
                    : nodes[i].main || nodes[j].main
                      ? 0.45
                      : 0.25;
                if (Math.random() < prob) {
                  var mx = (nodes[i].x + nodes[j].x) / 2;
                  var my = (nodes[i].y + nodes[j].y) / 2;
                  var perp =
                    Math.atan2(
                      nodes[j].y - nodes[i].y,
                      nodes[j].x - nodes[i].x,
                    ) +
                    Math.PI / 2;
                  var bend = (Math.random() - 0.5) * d * 0.35;
                  conns.push({
                    from: i,
                    to: j,
                    cpx: mx + Math.cos(perp) * bend,
                    cpy: my + Math.sin(perp) * bend,
                    opacity: 0.03 + Math.random() * 0.07,
                  });
                  nodeConns++;
                }
              }
            }
            /* Ensure every node has at least one connection */
            if (nodeConns === 0) {
              var closest = -1,
                closestD = 99999;
              for (j = 0; j < nodes.length; j++) {
                if (j === i) continue;
                d = ddist(nodes[i], nodes[j]);
                if (d < closestD) {
                  closestD = d;
                  closest = j;
                }
              }
              if (closest >= 0) {
                var mx2 = (nodes[i].x + nodes[closest].x) / 2;
                var my2 = (nodes[i].y + nodes[closest].y) / 2;
                conns.push({
                  from: i,
                  to: closest,
                  cpx: mx2 + (Math.random() - 0.5) * 40,
                  cpy: my2 + (Math.random() - 0.5) * 40,
                  opacity: 0.05,
                });
              }
            }
          }

          /* Seed initial arrows on ~35% of connections */
          for (i = 0; i < conns.length; i++) {
            if (Math.random() < 0.35) spawnArrow(i);
          }
        }

        /* ── UPDATE — physics + arrow movement ── */
        function update() {
          time += 0.016;
          var i, n, dx, dy, md;

          /* Node drift + mouse repulsion */
          for (i = 0; i < nodes.length; i++) {
            n = nodes[i];
            dx = mouse.x - n.x;
            dy = mouse.y - n.y;
            md = Math.sqrt(dx * dx + dy * dy);
            if (md < 180 && md > 0) {
              var force = ((180 - md) / 180) * 0.25;
              n.vx -= (dx / md) * force * 0.015;
              n.vy -= (dy / md) * force * 0.015;
            }
            n.vx += (n.baseX - n.x) * 0.004;
            n.vy += (n.baseY - n.y) * 0.004;
            n.vx *= 0.96;
            n.vy *= 0.96;
            n.x += n.vx;
            n.y += n.vy;
          }

          /* Move arrows along paths */
          for (i = arrows.length - 1; i >= 0; i--) {
            var ar = arrows[i];
            ar.t += ar.speed;
            if (ar.t >= 1) {
              var cn = conns[ar.ci];
              var tn = nodes[cn.to];
              spawnBurst(tn.x, tn.y, ar.color);
              arrows.splice(i, 1);
              if (Math.random() < 0.65) spawnArrow(ar.ci);
            }
          }

          /* Randomly spawn new arrows */
          if (Math.random() < 0.06 && arrows.length < 50) {
            spawnArrow(Math.floor(Math.random() * conns.length));
          }

          /* Update particles */
          for (i = particles.length - 1; i >= 0; i--) {
            var pt = particles[i];
            pt.x += pt.vx;
            pt.y += pt.vy;
            pt.vx *= 0.95;
            pt.vy *= 0.95;
            pt.life -= 0.035;
            if (pt.life <= 0) particles.splice(i, 1);
          }
        }

        /* ── DRAW — renders everything to canvas ── */
        function draw() {
          ctx.clearRect(0, 0, W, H);

          var i, cn, f, t, ar, pos, tan, angle, rgb, sz;

          /* Connections — bezier curves */
          for (i = 0; i < conns.length; i++) {
            cn = conns[i];
            f = nodes[cn.from];
            t = nodes[cn.to];
            ctx.beginPath();
            ctx.moveTo(f.x, f.y);
            ctx.quadraticCurveTo(cn.cpx, cn.cpy, t.x, t.y);
            ctx.strokeStyle = "rgba(57,255,20," + cn.opacity + ")";
            ctx.lineWidth = 0.6;
            ctx.stroke();
          }

          /* Arrows — directional chevrons with trail */
          for (i = 0; i < arrows.length; i++) {
            ar = arrows[i];
            cn = conns[ar.ci];
            f = nodes[cn.from];
            t = nodes[cn.to];
            var cp = { x: cn.cpx, y: cn.cpy };
            pos = bezPt(f, cp, t, ar.t);
            tan = bezTan(f, cp, t, ar.t);
            angle = Math.atan2(tan.y, tan.x);
            rgb = h2r(ar.color);
            sz = ar.size;

            /* Motion trail */
            for (var tr = 1; tr <= 5; tr++) {
              var tt = ar.t - tr * 0.025;
              if (tt < 0) continue;
              var tp = bezPt(f, cp, t, tt);
              var ta = 1 - tr / 5;
              ctx.beginPath();
              ctx.arc(tp.x, tp.y, 1.2 * ta, 0, Math.PI * 2);
              ctx.fillStyle =
                "rgba(" +
                rgb.r +
                "," +
                rgb.g +
                "," +
                rgb.b +
                "," +
                ta * 0.25 +
                ")";
              ctx.fill();
            }

            /* Arrow head (chevron/dart shape) */
            ctx.save();
            ctx.translate(pos.x, pos.y);
            ctx.rotate(angle);
            ctx.beginPath();
            ctx.moveTo(sz, 0);
            ctx.lineTo(-sz * 0.5, -sz * 0.45);
            ctx.lineTo(-sz * 0.2, 0);
            ctx.lineTo(-sz * 0.5, sz * 0.45);
            ctx.closePath();
            ctx.fillStyle =
              "rgba(" + rgb.r + "," + rgb.g + "," + rgb.b + ",0.85)";
            ctx.fill();
            ctx.restore();

            /* Arrow glow */
            ctx.beginPath();
            ctx.arc(pos.x, pos.y, sz * 1.8, 0, Math.PI * 2);
            ctx.fillStyle =
              "rgba(" + rgb.r + "," + rgb.g + "," + rgb.b + ",0.06)";
            ctx.fill();
          }

          /* Particles (burst on arrival) */
          for (i = 0; i < particles.length; i++) {
            var pt = particles[i];
            rgb = h2r(pt.color);
            ctx.beginPath();
            ctx.arc(pt.x, pt.y, pt.size * pt.life, 0, Math.PI * 2);
            ctx.fillStyle =
              "rgba(" +
              rgb.r +
              "," +
              rgb.g +
              "," +
              rgb.b +
              "," +
              pt.life * 0.5 +
              ")";
            ctx.fill();
          }

          /* Nodes — tool icons + breathing rings */
          for (i = 0; i < nodes.length; i++) {
            var nd = nodes[i];
            if (nd.main) {
              /* Breathing ring */
              var breathe = 0.06 + 0.04 * Math.sin(time * 1.2 + nd.pulsePhase);
              ctx.beginPath();
              ctx.arc(
                nd.x,
                nd.y,
                nd.iconSize + 10 + 3 * Math.sin(time + nd.pulsePhase),
                0,
                Math.PI * 2,
              );
              ctx.strokeStyle = "rgba(57,255,20," + breathe + ")";
              ctx.lineWidth = 0.5;
              ctx.stroke();

              /* Tool icon */
              ctx.save();
              ctx.translate(nd.x, nd.y);
              ctx.strokeStyle = "rgba(57,255,20,0.2)";
              ctx.fillStyle = "rgba(57,255,20,0.15)";
              ctx.lineWidth = 1.0;
              ctx.lineCap = "round";
              ctx.lineJoin = "round";
              TOOLS[nd.tool].draw(ctx, nd.iconSize);
              ctx.restore();

              /* Center dot */
              ctx.beginPath();
              ctx.arc(nd.x, nd.y, 2, 0, Math.PI * 2);
              ctx.fillStyle = "rgba(57,255,20,0.4)";
              ctx.fill();
            } else {
              /* Secondary node — tiny dot */
              ctx.beginPath();
              ctx.arc(nd.x, nd.y, 1.5, 0, Math.PI * 2);
              ctx.fillStyle = "rgba(0,212,255,0.2)";
              ctx.fill();
            }
          }
        }

        /* ── ANIMATION LOOP ── */
        function loop() {
          update();
          draw();
          raf = requestAnimationFrame(loop);
        }

        /* ── START — called on every page load ── */
        function start() {
          stop();
          canvas = document.getElementById("node-graph");
          if (!canvas) return;
          ctx = canvas.getContext("2d");
          if (!ctx) return;

          var wrap = canvas.parentElement;
          if (!wrap) return;

          wrap.addEventListener("mousemove", onMouseMove);
          wrap.addEventListener("mouseleave", onMouseLeave);

          running = true;
          init();
          loop();
        }

        /* ── STOP — cleanup on navigation ── */
        function stop() {
          if (raf) {
            cancelAnimationFrame(raf);
            raf = null;
          }
          running = false;
          nodes = [];
          conns = [];
          arrows = [];
          particles = [];

          /* Remove old listeners if canvas exists */
          var oldWrap = canvas ? canvas.parentElement : null;
          if (oldWrap) {
            oldWrap.removeEventListener("mousemove", onMouseMove);
            oldWrap.removeEventListener("mouseleave", onMouseLeave);
          }
        }

        /* ── MOUSE HANDLERS (named so they can be removed) ── */
        function onMouseMove(e) {
          var rect = e.currentTarget.getBoundingClientRect();
          mouse.x = e.clientX - rect.left;
          mouse.y = e.clientY - rect.top;
        }
        function onMouseLeave() {
          mouse.x = -9999;
          mouse.y = -9999;
        }

        /* ── RESIZE HANDLER ── */
        window.addEventListener("resize", function () {
          if (running && canvas) {
            resize();
            init();
          }
        });

        /* ── ASTRO VIEW TRANSITIONS HOOKS ── */
        document.addEventListener("astro:page-load", start);
        document.addEventListener("astro:before-swap", stop);

        /* ── FALLBACK: if no View Transitions, start immediately ── */
        if (
          document.readyState === "complete" ||
          document.readyState === "interactive"
        ) {
          start();
        }
      })();
    </script>
  </main>

