      font-weight: 800;
      letter-spacing: -0.035em;
      margin-bottom: 1rem;
    }

    .page-desc {
      font-size: 1rem;
      color: var(--text-muted);
      line-height: 1.7;
      max-width: 58ch;
    }

    .tags-strip {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-bottom: 3rem;
    }

    .section-label {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-subtle);
      margin-bottom: 1.5rem;
    }

    .project-section {
      margin-bottom: 3.5rem;
    }

    /* Featured grid */
    .featured-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.25rem;
    }

    .project-card {
      display: block;
      text-decoration: none;
    }

    .card-inner {
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
      gap: 1.25rem;
    }

    .card-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 0.75rem;
    }

    .card-badge {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      flex-shrink: 0;
    }

    .featured-badge {
      font-family: var(--font-mono);
      font-size: 0.65rem;
      color: var(--accent-green);
      background: rgba(57, 255, 20, 0.08);
      border: 1px solid rgba(57, 255, 20, 0.2);
      padding: 0.2rem 0.55rem;
      border-radius: 999px;
      letter-spacing: 0.06em;
    }

    .card-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.4rem;
    }

    .card-arrow {
      color: var(--text-subtle);
      flex-shrink: 0;
      transition:
        color 0.2s ease,
        transform 0.2s ease;
    }

    .project-card:hover .card-arrow,
    .project-row:hover .card-arrow {
      color: var(--accent-green);
      transform: translate(2px, -2px);
    }

    .card-body {
      flex: 1;
    }

    .card-title {
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: -0.015em;
      margin-bottom: 0.5rem;
      color: var(--text-primary);
      transition: color 0.2s ease;
    }

    .project-card:hover .card-title {
      color: var(--accent-soft);
    }

    .card-desc {
      font-size: 0.875rem;
      color: var(--text-muted);
      line-height: 1.6;
    }

    .card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .card-date {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      color: var(--text-subtle);
    }

    .card-status {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      padding: 0.2rem 0.55rem;
      border-radius: 999px;
      text-transform: capitalize;
    }

    .status-completed {
      color: var(--accent-soft);
      background: rgba(0, 255, 136, 0.08);
      border: 1px solid rgba(0, 255, 136, 0.2);
    }

    .status-in-progress {
      color: #fbbf24;
      background: rgba(251, 191, 36, 0.08);
      border: 1px solid rgba(251, 191, 36, 0.2);
    }

    /* Projects list (non-featured) */
    .projects-list {
      display: flex;
      flex-direction: column;
