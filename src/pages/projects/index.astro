---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = (await getCollection('projects'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featuredProjects = allProjects.filter((p) => p.data.featured);
const otherProjects = allProjects.filter((p) => !p.data.featured);

const allTags = [...new Set(allProjects.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Projects"
  description="AI automation workflows, DevOps infrastructure setups, and Cloudflare security projects by Sudarshan Kotian."
>
  <main class="projects-main">
    <div class="section-container">

      <!-- Header -->
      <header class="page-header animate-fade-up">
        <p class="eyebrow">All work</p>
        <h1 class="page-title">Projects</h1>
        <p class="page-desc">
          A collection of AI automation workflows, DevOps infrastructure builds,
          and security engineering projects — built with production environments in mind.
        </p>
      </header>

      <!-- Tag filter display (decorative, not JS-driven) -->
      <div class="tags-strip animate-fade-up animate-fade-up-d1">
        {allTags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>

      <!-- Featured -->
      {featuredProjects.length > 0 &&
        <section class="project-section animate-fade-up animate-fade-up-d2">
          <h2 class="section-label">Featured</h2>
          <div class="projects-grid featured-grid">
            {featuredProjects.map((project) =>
              <a href={`/projects/${project.id}`} class="project-card glass-card">
                <div class="card-inner">
                  <div class="card-top">
                    <div class="card-tags">
                      {project.data.tags.slice(0, 3).map((tag: string) =>
                        <span class="tag">{tag}</span>
                      )}
                    </div>
                    <div class="card-badge">
                      <span class="featured-badge">Featured</span>
                      <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="card-arrow" aria-hidden="true">
                        <path d="M3.5 14.5L14.5 3.5M14.5 3.5H6.5M14.5 3.5V11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                  </div>
                  <div class="card-body">
                    <h3 class="card-title">{project.data.title}</h3>
                    <p class="card-desc">{project.data.description}</p>
                  </div>
                  <div class="card-footer">
                    <time class="card-date">
                      {project.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
                    </time>
                    <span class={`card-status status-${project.data.status}`}>
                      {project.data.status}
                    </span>
                  </div>
                </div>
              </a>
            )}
          </div>
        </section>
      }

      <!-- Other projects -->
      {otherProjects.length > 0 &&
        <section class="project-section animate-fade-up animate-fade-up-d3">
          <h2 class="section-label">All projects</h2>
          <div class="projects-list">
            {otherProjects.map((project) =>
              <a href={`/projects/${project.id}`} class="project-row glass-card">
                <div class="row-left">
                  <h3 class="row-title">{project.data.title}</h3>
                  <p class="row-desc">{project.data.description}</p>
                  <div class="row-tags">
                    {project.data.tags.slice(0, 4).map((tag: string) =>
                      <span class="tag">{tag}</span>
                    )}
                  </div>
                </div>
                <div class="row-right">
                  <time class="card-date">
                    {project.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short' })}
                  </time>
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none" class="card-arrow" aria-hidden="true">
                    <path d="M3.5 14.5L14.5 3.5M14.5 3.5H6.5M14.5 3.5V11.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </a>
            )}
          </div>
        </section>
      }

    </div>
  </main>
</BaseLayout>

<style>
  .projects-main {
    padding-top: 120px;
    padding-bottom: 4rem;
  }

  .page-header {
    max-width: 620px;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-green);
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    margin-bottom: 1rem;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 58ch;
  }

  .tags-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-subtle);
    margin-bottom: 1.5rem;
  }

  .project-section { margin-bottom: 3.5rem; }

  /* Featured grid */
  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
  }

  .project-card {
    display: block;
    text-decoration: none;
  }

  .card-inner {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .card-badge {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .featured-badge {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--accent-green);
    background: rgba(57, 255, 20, 0.08);
    border: 1px solid rgba(57, 255, 20, 0.2);
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    letter-spacing: 0.06em;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .card-arrow {
    color: var(--text-subtle);
    flex-shrink: 0;
    transition: color 0.2s ease, transform 0.2s ease;
  }

  .project-card:hover .card-arrow,
  .project-row:hover .card-arrow {
    color: var(--accent-green);
    transform: translate(2px, -2px);
  }

  .card-body { flex: 1; }

  .card-title {
    font-size: 1.1rem;
    font-weight: 700;
    letter-spacing: -0.015em;
    margin-bottom: 0.5rem;
    color: var(--text-primary);
    transition: color 0.2s ease;
  }

  .project-card:hover .card-title { color: var(--accent-soft); }

  .card-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-date {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-subtle);
  }

  .card-status {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    padding: 0.2rem 0.55rem;
    border-radius: 999px;
    text-transform: capitalize;
  }

  .status-completed {
    color: var(--accent-soft);
    background: rgba(0, 255, 136, 0.08);
    border: 1px solid rgba(0, 255, 136, 0.2);
  }

  .status-in-progress {
    color: #fbbf24;
    background: rgba(251, 191, 36, 0.08);
    border: 1px solid rgba(251, 191, 36, 0.2);
  }

  /* Projects list (non-featured) */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    text-decoration: none;
    padding: 1.5rem;
  }

  .row-left { flex: 1; }

  .row-title {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
    margin-bottom: 0.4rem;
    transition: color 0.2s ease;
  }

  .project-row:hover .row-title { color: var(--accent-soft); }

  .row-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .row-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .row-right {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-shrink: 0;
  }

  @media (max-width: 640px) {
    .projects-main { padding-top: 100px; }
    .featured-grid { grid-template-columns: 1fr; }
    .project-row { flex-direction: column; align-items: flex-start; }
    .row-right { flex-direction: row-reverse; }
  }
</style>