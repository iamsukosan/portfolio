    }

    .row-right {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-shrink: 0;
    }

    @media (max-width: 640px) {
      .projects-main {
        padding-top: 100px;
      }
      .featured-grid {
        grid-template-columns: 1fr;
      }
      .project-row {
        flex-direction: column;
        align-items: flex-start;
      }
      .row-right {
        flex-direction: row-reverse;
      }
    }
  </style>
</BaseLayout>
