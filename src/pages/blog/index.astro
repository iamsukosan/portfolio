---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = (await getCollection('blog'))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const allTags = [...new Set(allPosts.flatMap((p) => p.data.tags))].sort();
---

<BaseLayout
  title="Blog"
  description="Writing on AI automation, DevOps infrastructure, Cloudflare, self-hosting, and engineering systems that scale."
>
  <main class="blog-main">
    <div class="section-container">

      <!-- Header -->
      <header class="page-header animate-fade-up">
        <p class="eyebrow">Writing</p>
        <h1 class="page-title">Blog</h1>
        <p class="page-desc">
          Thoughts on AI automation, DevOps infrastructure, Cloudflare security,
          and the engineering systems that make modern software run.
        </p>
      </header>

      <!-- Tags -->
      <div class="tags-strip animate-fade-up animate-fade-up-d1">
        {allTags.map((tag) => (
          <span class="tag">{tag}</span>
        ))}
      </div>

      <!-- Post list -->
      <div class="posts-list animate-fade-up animate-fade-up-d2">
        {allPosts.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card glass-card">
            <div class="post-card-inner">
              <div class="post-card-meta">
                <time class="post-date" datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <div class="post-card-tags">
                  {post.data.tags.slice(0, 3).map((tag) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
              <h2 class="post-card-title">{post.data.title}</h2>
              <p class="post-card-desc">{post.data.description}</p>
              <span class="read-more">
                Read post
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2 7H12M12 7L8 3M12 7L8 11" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>

      {allPosts.length === 0 && (
        <div class="empty-state">
          <p>No posts yet. Check back soon.</p>
        </div>
      )}

    </div>
  </main>
</BaseLayout>

<style>
  .blog-main {
    padding-top: 120px;
    padding-bottom: 4rem;
  }

  .page-header {
    max-width: 620px;
    margin-bottom: 2.5rem;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-green);
    margin-bottom: 0.75rem;
  }

  .page-title {
    font-size: clamp(2rem, 4vw, 3.5rem);
    font-weight: 800;
    letter-spacing: -0.035em;
    margin-bottom: 1rem;
  }

  .page-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 58ch;
  }

  .tags-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 3rem;
  }

  /* Post cards */
  .posts-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .post-card {
    display: block;
    text-decoration: none;
  }

  .post-card-inner {
    padding: 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-date {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-subtle);
  }

  .post-card-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .post-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--text-primary);
    line-height: 1.3;
    transition: color 0.2s ease;
  }

  .post-card:hover .post-card-title { color: var(--accent-soft); }

  .post-card-desc {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.65;
    max-width: 70ch;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--text-subtle);
    margin-top: 0.25rem;
    transition: color 0.2s ease;
  }

  .post-card:hover .read-more { color: var(--accent-green); }

  .empty-state {
    text-align: center;
    padding: 4rem 0;
    color: var(--text-subtle);
    font-size: 0.9rem;
  }

  @media (max-width: 640px) {
    .blog-main { padding-top: 100px; }
    .post-card-inner { padding: 1.25rem; }
  }
</style>
