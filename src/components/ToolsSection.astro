  const logos: Record<string, string> = {
    Docker: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M13 4h2v2h-2V4Zm-3 0h2v2h-2V4ZM7 4h2v2H7V4Zm6 3h2v2h-2V7Zm-3 0h2v2h-2V7ZM7 7h2v2H7V7ZM4 7h2v2H4V7Zm6 3h2v2h-2v-2ZM7 10h2v2H7v-2ZM4 10h2v2H4v-2Z" fill="${color}"/><path d="M22.5 11.2c-.4-.3-1.3-.8-2.4-.6-.2-1.2-1-1.8-1.5-2.2l-.3.4c.6.5 1.2 1.3 1.3 2.4-1.3-.5-2.6-.4-3.2-.3-3.1.1-5.8.1-8.2 1.2C7 12.7 6 13.8 5.4 15.4c-.8 2.2-.5 6 2.4 9.1h.6c-.7-.8-2.4-3.5-2-7.5.3-2.6 2-4.3 5.1-4.7 2.3-.3 5.8-.1 8.3 1.5l.3-.3c.3.2.6.3 1 .3 1 0 1.6-.6 1.6-.6l-.2-.3c-.3.2-.6.4-1 .3Z" fill="${color}" opacity="0.5"/></svg>`,
    Coolify: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="3" y="3" width="18" height="18" rx="4" stroke="${color}" stroke-width="1.8" fill="none"/><path d="M8 12.5L10.5 15L16 9" stroke="${color}" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    Cloudflare: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M16.5 16.5H6.7c-.2 0-.3-.1-.3-.2 0-.1 0-.2.1-.3l1.7-2.4c.2-.3.5-.4.8-.4h9.3c.1 0 .2 0 .2.1 1-2.8-.3-4.7-2.7-5.1-.5-.1-1-.1-1.4 0C13.6 6.8 12 5.9 10.4 6.1 8.9 6.3 7.7 7.3 7.2 8.7c-1.9-.4-3.5 1-3.5 2.8 0 .3 0 .6.1.9-.9.5-1.4 1.3-1.5 2.3-.1 1.1.5 2.2 1.5 2.7.3.1.6.2.9.2h11.8c.2 0 .3-.1.3-.3 0-.1 0-.2-.1-.2l-1.3-1.5c-.2-.2-.4-.3-.7-.3h.3Z" fill="${color}"/><path d="M18.5 9.5c.3 0 .5.1.7.3l1.3 1.5c.1.1.1.2.1.3 0 .2-.1.3-.3.3h-2.6" stroke="${color}" stroke-width="1" fill="none" opacity="0.6"/></svg>`,
    Ubuntu: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10" stroke="${color}" stroke-width="1.5" fill="none"/><circle cx="12" cy="5.5" r="1.8" fill="${color}"/><circle cx="6.4" cy="15.5" r="1.8" fill="${color}"/><circle cx="17.6" cy="15.5" r="1.8" fill="${color}"/><path d="M10.2 6.3L7.8 10.5M13.8 6.3L16.2 10.5M6.5 13.5h11" stroke="${color}" stroke-width="1.2" opacity="0.5"/></svg>`,
