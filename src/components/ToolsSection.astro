    GitHub: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.42 2.87 8.17 6.84 9.5.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34-.46-1.16-1.11-1.47-1.11-1.47-.91-.62.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.87 1.52 2.34 1.07 2.91.83.09-.65.35-1.09.63-1.34-2.22-.25-4.55-1.11-4.55-4.92 0-1.11.38-2 1.03-2.71-.1-.25-.45-1.29.1-2.64 0 0 .84-.27 2.75 1.02.79-.22 1.65-.33 2.5-.33.85 0 1.71.11 2.5.33 1.91-1.29 2.75-1.02 2.75-1.02.55 1.35.2 2.39.1 2.64.65.71 1.03 1.6 1.03 2.71 0 3.82-2.34 4.66-4.57 4.91.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12c0-5.52-4.48-10-10-10Z" fill="${color}"/></svg>`,
    "Claude API": `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M16.1 8.2l-4.7 8.6-2.5-4.3 4.7-8.6 2.5 4.3Z" fill="${color}"/><path d="M12.8 12.5L7.5 12.5l2.5 4.3 5.3 0-2.5-4.3Z" fill="${color}" opacity="0.7"/></svg>`,
    n8n: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><rect x="2" y="9" width="6" height="6" rx="1.5" stroke="${color}" stroke-width="1.5" fill="none"/><rect x="9" y="9" width="6" height="6" rx="1.5" stroke="${color}" stroke-width="1.5" fill="none"/><rect x="16" y="9" width="6" height="6" rx="1.5" stroke="${color}" stroke-width="1.5" fill="none"/><path d="M8 12h1M15 12h1" stroke="${color}" stroke-width="1.5" stroke-linecap="round"/></svg>`,
    Python: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M11.9 2c-1.5 0-4.1.4-4.1 2.6V7h4.2v.8H6.2C4.8 7.8 3 8.7 3 12c0 3.3 1.5 4.2 3.2 4.2H8V14c0-1.6 1.3-3 3-3h4c1.4 0 2.5-1.1 2.5-2.5V5c0-1.5-1.5-2.6-3.3-2.9-.7-.1-1.5-.1-2.3-.1Zm-2.2 1.8c.5 0 .9.4.9.9s-.4.9-.9.9-.9-.4-.9-.9.4-.9.9-.9Z" fill="${color}"/><path d="M12.1 22c1.5 0 4.1-.4 4.1-2.6V17h-4.2v-.8h5.8c1.4 0 3.2-.9 3.2-4.2 0-3.3-1.5-4.2-3.2-4.2H16V10c0 1.6-1.3 3-3 3H9c-1.4 0-2.5 1.1-2.5 2.5V19c0 1.5 1.5 2.6 3.3 2.9.7.1 1.5.1 2.3.1Zm2.2-1.8c-.5 0-.9-.4-.9-.9s.4-.9.9-.9.9.4.9.9-.4.9-.9.9Z" fill="${color}" opacity="0.7"/></svg>`,
    WordPress: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10" stroke="${color}" stroke-width="1.5" fill="none"/><path d="M3.5 12l4.8 8.3M8.8 7h.5l3.3 9.7L15 10.2l1 2.5H20M12.4 20.8l3.5-9.6M20.2 13.5c.2-.8.3-1 .3-1.5 0-1.5-.8-2.5-.8-2.5" stroke="${color}" stroke-width="1.2" stroke-linecap="round" fill="none"/></svg>`,
    Astro: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M8.5 18.5c-.7-.9-.9-2.2-.5-3.9l2-8.2c.1-.3.3-.4.5-.4h3c.2 0 .4.1.5.4l2 8.2c.4 1.7.2 3-.5 3.9" stroke="${color}" stroke-width="1.5" stroke-linecap="round" fill="none"/><path d="M8.5 18.5c1 .5 2.2.7 3.5.7s2.5-.2 3.5-.7" stroke="${color}" stroke-width="1.5" stroke-linecap="round" fill="none"/><circle cx="12" cy="14" r="1.2" fill="${color}"/></svg>`,
    "Next.js": `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="10" stroke="${color}" stroke-width="1.3" fill="none"/><path d="M10 8v8M17.5 8L12 16.5V8" stroke="${color}" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>`,
    "Tailwind CSS": `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M7.5 9C8.3 6.3 10 5 12.5 5c3.8 0 4.2 2.8 6 3.3 1.2.3 2.3 0 3-.8-.8 2.8-2.5 4-5 4-3.8 0-4.2-2.8-6-3.3-1.2-.3-2.3 0-3 .8Z" fill="${color}"/><path d="M4.5 15.5c.8-2.8 2.5-4 5-4 3.8 0 4.2 2.8 6 3.3 1.2.3 2.3 0 3-.8-.8 2.8-2.5 4-5 4-3.8 0-4.2-2.8-6-3.3-1.2-.3-2.3 0-3 .8Z" fill="${color}" opacity="0.6"/></svg>`,
    PostgreSQL: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><ellipse cx="12" cy="6.5" rx="7.5" ry="3" stroke="${color}" stroke-width="1.3" fill="none"/><path d="M4.5 6.5v11c0 1.66 3.36 3 7.5 3s7.5-1.34 7.5-3v-11" stroke="${color}" stroke-width="1.3" fill="none"/><path d="M4.5 11.5c0 1.66 3.36 3 7.5 3s7.5-1.34 7.5-3" stroke="${color}" stroke-width="1.3" fill="none"/><path d="M4.5 16.5c0 1.66 3.36 3 7.5 3s7.5-1.34 7.5-3" stroke="${color}" stroke-width="1.3" fill="none" opacity="0.5"/></svg>`,
    Redis: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M21 12l-9 5-9-5" stroke="${color}" stroke-width="1.3" fill="none"/><path d="M21 8.5l-9 5-9-5" stroke="${color}" stroke-width="1.3" fill="none" opacity="0.5"/><path d="M21 15.5l-9 5-9-5" stroke="${color}" stroke-width="1.3" fill="none" opacity="0.3"/><path d="M12 3l3.5 2-3.5 2L8.5 5 12 3Z" fill="${color}"/><circle cx="6" cy="7.5" r="1" fill="${color}" opacity="0.7"/><path d="M14.5 6.5l3 1.5" stroke="${color}" stroke-width="1.5" stroke-linecap="round"/></svg>`,
  };
  return logos[name] || `<svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="8" stroke="${color}" stroke-width="1.5" fill="none"/></svg>`;
}

const categories = [
  {
    label: "Infrastructure & DevOps",
    tools: [
      { name: "Docker", color: "#2496ED" },
      { name: "Coolify", color: "#6B16ED" },
      { name: "Cloudflare", color: "#F6821F" },
      { name: "Ubuntu", color: "#E95420" },
      { name: "Nginx", color: "#009639" },
      { name: "GitHub", color: "#ffffff" },
    ],
  },
  {
    label: "AI & Automation",
    tools: [
      { name: "Claude API", color: "#D4A27F" },
      { name: "n8n", color: "#EA4B71" },
      { name: "Python", color: "#3776AB" },
    ],
  },
  {
    label: "Web & Development",
    tools: [
      { name: "WordPress", color: "#21759B" },
      { name: "Astro", color: "#FF5D01" },
      { name: "Next.js", color: "#ffffff" },
      { name: "Tailwind CSS", color: "#06B6D4" },
    ],
  },
  {
    label: "Data & Storage",
    tools: [
      { name: "PostgreSQL", color: "#4169E1" },
      { name: "Redis", color: "#DC382D" },
    ],
  },
];
---

<section class="tools-section">
  <div class="section-container">
    <p class="section-eyebrow">Stack</p>
    <h2 class="tools-heading">Tools & technologies</h2>
    <p class="tools-sub">
      The infrastructure, platforms, and tools I use to build AI automations,
      manage servers, and ship projects.
    </p>

    <div class="tools-categories">
      {categories.map((cat) => (
        <div class="tools-cat">
          <div class="tools-cat-head">
            <span class="tools-cat-label">{cat.label}</span>
            <span class="tools-cat-line" />
          </div>
          <div class="tools-cat-grid">
            {cat.tools.map((tool) => (
              <div class="tool-card">
                <div class="tool-logo-wrap">
                  <Fragment set:html={logoSvg(tool.name, tool.color)} />
                </div>
                <span class="tool-name">{tool.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .tools-section {
    padding: 2rem 0 3rem;
  }

  .tools-heading {
    font-size: clamp(1.4rem, 2.5vw, 2rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    color: var(--text-primary);
    margin-bottom: 0.5rem;
  }

  .tools-sub {
    font-size: 0.95rem;
    color: var(--text-muted);
    max-width: 52ch;
    line-height: 1.7;
    margin-bottom: 2.25rem;
  }

  .tools-categories {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .tools-cat-head {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.85rem;
  }

  .tools-cat-label {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-subtle);
    white-space: nowrap;
  }

  .tools-cat-line {
    flex: 1;
    height: 1px;
    background: var(--border-default);
  }

  .tools-cat-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .tool-card {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.55rem 0.9rem 0.55rem 0.65rem;
    border-radius: 10px;
    border: 1px solid var(--border-default);
    background: rgba(7, 20, 40, 0.5);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    cursor: default;
    transition:
      border-color 0.25s ease,
      background 0.25s ease,
      box-shadow 0.25s ease,
      transform 0.25s ease;
  }

  .tool-card:hover {
    border-color: var(--border-hover);
    background: rgba(7, 20, 40, 0.8);
    box-shadow:
      0 0 0 1px rgba(57, 255, 20, 0.1),
      0 4px 24px rgba(0, 0, 0, 0.3);
    transform: translateY(-2px);
  }

  .tool-logo-wrap {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .tool-logo-wrap :global(svg) {
    width: 20px;
    height: 20px;
  }

  .tool-name {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    white-space: nowrap;
    transition: color 0.2s ease;
  }

  .tool-card:hover .tool-name {
    color: var(--text-primary);
  }

  @media (max-width: 640px) {
    .tools-cat-grid {
      gap: 0.5rem;
    }

    .tool-card {
      padding: 0.5rem 0.75rem 0.5rem 0.55rem;
    }

    .tool-name {
      font-size: 0.75rem;
    }
  }
</style>


