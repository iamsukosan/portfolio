# Hashed Astro bundles — cache forever (filename changes on rebuild)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts, icons, images in public/ — long cache
/*.woff2
  Cache-Control: public, max-age=31536000, immutable
/*.woff
  Cache-Control: public, max-age=31536000, immutable
/*.ico
  Cache-Control: public, max-age=31536000, immutable

# HTML pages — CF edge caches, browser always revalidates
/*
  Cache-Control: public, max-age=0, must-revalidate

# Sitemap and RSS — short TTL
/sitemap.xml
  Cache-Control: public, max-age=3600
/rss.xml
  Cache-Control: public, max-age=3600